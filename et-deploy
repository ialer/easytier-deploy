#!/usr/bin/env python3
"""
EasyTier 跨平台部署管理工具
用法:
  et-deploy install     首次安装（交互式配置）
  et-deploy start       启动服务
  et-deploy stop        停止服务
  et-deploy restart     重启服务
  et-deploy status      查看状态
  et-deploy update      更新 EasyTier 核心
  et-deploy dashboard   启动监控仪表盘
  et-deploy uninstall   卸载
"""
import sys, os, argparse

def main():
    parser = argparse.ArgumentParser(
        prog='et-deploy',
        description='EasyTier 跨平台部署管理工具',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    sub = parser.add_subparsers(dest='command')

    sub.add_parser('install', help='首次安装')
    sub.add_parser('start', help='启动服务')
    sub.add_parser('stop', help='停止服务')
    sub.add_parser('restart', help='重启服务')
    sub.add_parser('status', help='查看状态')
    sub.add_parser('update', help='更新 EasyTier 核心')
    sub.add_parser('dashboard', help='启动监控仪表盘')
    sub.add_parser('uninstall', help='卸载')
    sub.add_parser('web-install', help='启动 Web 安装向导')

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return

    # 动态导入，避免启动时加载所有模块
    if args.command == 'install':
        from core.installer import run_install
        run_install()
    elif args.command == 'start':
        from core.service import service_start
        service_start()
    elif args.command == 'stop':
        from core.service import service_stop
        service_stop()
    elif args.command == 'restart':
        from core.service import service_restart
        service_restart()
    elif args.command == 'status':
        from core.service import service_status
        service_status()
    elif args.command == 'update':
        from core.downloader import update_core
        update_core()
    elif args.command == 'dashboard':
        from core.dashboard import run_dashboard
        run_dashboard()
    elif args.command == 'uninstall':
        from core.service import service_uninstall
        service_uninstall()
    elif args.command == 'web-install':
        from core.web_installer import run_web_installer
        run_web_installer()

if __name__ == '__main__':
    main()
